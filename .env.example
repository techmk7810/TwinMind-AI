# Application
APP_NAME=TwinMind AI
ENVIRONMENT=development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Backend
BACKEND_CORS_ORIGINS=http://localhost:3000
JWT_SECRET_KEY=change-me-for-local-development
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_COOKIE_NAME=tm_refresh_token
REFRESH_TOKEN_COOKIE_SECURE=false

# PostgreSQL
POSTGRES_USER=twinmind
POSTGRES_PASSWORD=twinmind
POSTGRES_DB=twinmind
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://twinmind:twinmind@db:5432/twinmind
